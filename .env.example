# Telegram
TELEGRAM_BOT_TOKEN=replace_me
SINGLE_USERNAME=default
GROUP_GENERAL_CHAT_ID=-1000000000000
ALLOWED_USERNAMES=

# Web UI (inside container)
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8787

# LLM / Ollama endpoint
OLLAMA_HOST_IP=127.0.0.1
OLLAMA_HOST_PORT=11534
OLLAMA_SERVER_BASE=http://127.0.0.1:11534
OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=not-needed

# Embeddings
EMBEDDING_MODEL=embed-cpu:latest
EMBEDDING_OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL_DIMS=768

# Qdrant
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=agent_memory

# Optional tool backends
BROWSER_BASE_URL=http://127.0.0.1:9377
SANDBOX_BASE_URL=http://127.0.0.1:1000
SEARXNG_BASE_URL=http://127.0.0.1:8081

# Optional reddit credentials
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
